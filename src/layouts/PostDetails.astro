---
import Layout from "@layouts/Layout.astro";
import AppNavbar from "@components/AppNavbar";
import AppFooter from "@components/AppFooter.astro";

import SmallCard from "@components/SmallCard.astro";
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@utils/slugify";
import { SITE } from "@config";

import { getCollection } from "astro:content";
import getSortedPosts from "@utils/getSortedPosts";
import getUniqueTags from "@utils/getUniqueTags";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const {
  title,
  author,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
} = post.data;

const { Content } = await post.render();

const ogImageUrl = typeof ogImage === "string" ? ogImage : ogImage?.src;
const ogUrl = new URL(
  ogImageUrl ?? `/posts/${slugifyStr(title)}.png`,
  Astro.url.origin
).href;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage: ogUrl,
  scrollSmooth: true,
};

// Format dates nicely
const pubDateStr = new Date(pubDatetime).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  hour: "numeric",
  minute: "2-digit",
});

// Grab recent posts for "Related articles"
const allPosts = await getCollection("blog");
const recentRelated = getSortedPosts(allPosts)
  .filter(p => p.slug !== post.slug)
  .slice(0, 4);

const tagsAll = getUniqueTags(allPosts);

const navLinks = [
  { label: "HOME", href: "/" },
  ...tagsAll.map(t => ({
    label: t.tagName.toUpperCase(),
    href: `/tags/${t.tag}`,
  })),
];
---

<Layout {...layoutProps}>
  <AppNavbar
    client:load
    activeHref={`/tags/${tags[0] ? slugifyStr(tags[0]) : "news"}`}
    navLinks={navLinks}
  />

  <div class="jk-page bg-[#f5f6fa] min-h-screen text-[#1e1e1e] font-display">
    {/* ── Content ── */}
    <div
      class="max-w-[1080px] mx-auto px-5 sm:px-8 lg:px-12 pt-[28px] sm:pt-[34px] lg:pt-[42px] pb-4 bg-white sm:rounded-3xl border border-black/5 sm:mt-6 lg:mt-8 mb-8 shadow-[0_12px_40px_rgba(0,0,0,0.06)] transition-all duration-500"
    >
      {/* ── Top Header Section (TikTok-inspired) ── */}
      <div class="relative flex flex-col gap-5 mb-8 mt-2">
        <div class="flex items-center justify-between w-full">
          {/* Floating Back Button */}
          <button
            onclick="(() => (history.length === 1) ? window.location = '/' : history.back())()"
            class="group flex items-center justify-center w-[42px] h-[42px] bg-black/[0.04] hover:bg-black/[0.08] active:bg-black/[0.12] rounded-full transition-all duration-150 ease-out cursor-pointer text-[#1e1e1e] hover:scale-[1.05] active:scale-[0.92] shadow-[0_2px_8px_rgba(0,0,0,0.02)]"
            aria-label="Go Back"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="group-hover:-translate-x-0.5 transition-transform duration-150"
            >
              <path d="M19 12H5M12 19l-7-7 7-7"></path>
            </svg>
          </button>

          {/* Category Badge (Clickable Nav Pill) */}
          <a
            href={`/tags/${tags[0] ? slugifyStr(tags[0]) : "news"}`}
            class="bg-[#1e1e1e] hover:bg-[#0007d3] px-[16px] py-[8px] rounded-full shadow-sm hover:shadow-md transition-all duration-150 ease-out hover:-translate-y-0.5 active:translate-y-0 active:scale-95 flex items-center gap-1.5 no-underline group"
          >
            <span
              class="w-1.5 h-1.5 rounded-full bg-[#ff0050] group-hover:bg-white transition-colors duration-200"
            ></span>
            <span
              class="font-display font-extrabold text-[11px] tracking-wider text-white uppercase mt-[1px]"
            >
              {tags[0] || "NEWS"}
            </span>
          </a>
        </div>

        {/* Title */}
        <h1
          class="font-display font-black text-[28px] sm:text-[36px] lg:text-[46px] text-[#1e1e1e] leading-[1.1] tracking-tight"
        >
          {title}
        </h1>

        {/* Author and Date Meta (App-style inline) */}
        <div
          class="flex items-center gap-3 text-[14px] sm:text-[15px] font-display mt-1"
        >
          {
            author && (
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-[#0007d3] to-[#ff0050] flex items-center justify-center text-white text-[12px] font-bold shadow-sm">
                  {author.charAt(0).toUpperCase()}
                </div>
                <span class="font-bold text-[#1e1e1e]">{author}</span>
              </div>
            )
          }
          {author && <span class="text-[#1e1e1e]/30 font-bold">•</span>}
          <span class="font-semibold text-[#1e1e1e]/60">{pubDateStr}</span>
        </div>
      </div>
      <hr class="border-black/5 mb-8" />

      <article
        id="article"
        class="prose max-w-none w-full overflow-hidden break-words text-justify mt-8 mb-8 font-display"
      >
        <Content />
      </article>

      {/* ── Comments & Reactions (Zoomment) ── */}
      <div class="border-t-2 border-[#0007d3] pt-6 mb-12 mt-8">
        <h2
          class="font-display font-extrabold text-[17px] sm:text-[22px] text-[#000055] mb-6"
        >
          Community Discussion
        </h2>
        <div
          id="zoomment"
          data-theme="light"
          data-language="en"
          data-gravatar="monsterid"
          data-emotions="👍,👎,❤️,😂,😢,😮,😡"
          data-visitors="true"
        >
        </div>
        <script is:inline src="https://cdn.zoomment.com/zoomment.min.js"
        ></script>
      </div>

      {/* ── Related articles ── */}
      <div class="border-t-[2px] border-[#0007d3] pt-[22px] mb-8 lg:mb-12">
        <h2
          class="font-display font-extrabold text-[17px] sm:text-[22px] text-[#000055] mb-[18px]"
        >
          RELATED ARTICLES
        </h2>
        <div
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-[9px] sm:gap-[18px]"
        >
          {
            recentRelated.map(relatedPost => (
              <SmallCard
                post={relatedPost}
                category={relatedPost.data.tags[0] || "NEWS"}
              />
            ))
          }
        </div>
      </div>

      {/* ── Back to Home ── */}
      <div class="text-center pb-10">
        <a
          href="/"
          class="jk-btn inline-block bg-transparent border-2 border-[#0007d3] rounded-[20px] px-6 py-[10px] cursor-pointer font-display font-extrabold text-[#0007d3] hover:bg-[#0007d3] hover:text-white transition-colors text-[13px] no-underline"
        >
          ← BACK TO HOME
        </a>
      </div>
    </div>

    <AppFooter />
  </div>
</Layout>

<style>
  .prose {
    font-size: 16px;
    line-height: 1.8;
    letter-spacing: -0.01em;
  }
  @media (min-width: 640px) {
    .prose {
      font-size: 18px;
    }
  }
  @media (min-width: 1024px) {
    .prose {
      font-size: 19px;
      line-height: 1.85;
    }
  }
  .prose :global(p) {
    @apply mb-[22px];
  }
  .prose :global(img) {
    width: 100%;
    max-width: 100%;
    height: auto;
    border-radius: 10px;
    object-fit: cover;
    @apply shadow-sm;
  }
</style>
