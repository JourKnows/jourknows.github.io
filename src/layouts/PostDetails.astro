---
import Layout from "@layouts/Layout.astro";
import AppNavbar from "@components/AppNavbar";
import AppFooter from "@components/AppFooter.astro";
import ArticleReactions from "@components/ArticleReactions";
import SmallCard from "@components/SmallCard.astro";
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@utils/slugify";
import { SITE } from "@config";
import { HERO_IMG } from "@utils/constants";
import { getCollection } from "astro:content";
import getSortedPosts from "@utils/getSortedPosts";
import getUniqueTags from "@utils/getUniqueTags";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const {
  title,
  author,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  tags,
} = post.data;

const { Content } = await post.render();

const ogImageUrl = typeof ogImage === "string" ? ogImage : ogImage?.src;
const ogUrl = new URL(
  ogImageUrl ?? `/posts/${slugifyStr(title)}.png`,
  Astro.url.origin
).href;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage: ogUrl,
  scrollSmooth: true,
};

// Format dates nicely
const pubDateStr = new Date(pubDatetime).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  hour: "numeric",
  minute: "2-digit",
});

// Grab recent posts for "Related articles"
const allPosts = await getCollection("blog");
const recentRelated = getSortedPosts(allPosts)
  .filter(p => p.slug !== post.slug)
  .slice(0, 4);

const tagsAll = getUniqueTags(allPosts);
import { SECTION_COLORS } from "@utils/constants";
const mainCategoryKeys = Object.keys(SECTION_COLORS).filter(
  k => k !== "default"
);
const categoryTags = tagsAll.filter(t => mainCategoryKeys.includes(t.tag));

const navLinks = [
  { label: "HOME", href: "/" },
  ...categoryTags.map(t => ({
    label: t.tagName.toUpperCase(),
    href: `/tags/${t.tag}`,
  })),
];
---

<Layout {...layoutProps}>
  <AppNavbar
    client:load
    activeHref={`/tags/${tags[0] ? slugifyStr(tags[0]) : "news"}`}
    navLinks={navLinks}
  />

  <div class="jk-page bg-white min-h-screen text-[#1e1e1e] font-display">
    {/* ── Hero ── */}
    <div
      class="relative h-[270px] sm:h-[360px] lg:h-[450px] overflow-hidden bg-[#d9d9d9]"
    >
      {
        ogUrl && (
          <img src={ogUrl} alt={title} class="w-full h-full object-cover" />
        )
      }
      <div class="absolute inset-0 bg-gradient-to-b from-black/10 to-black/75">
      </div>
      <div
        class="absolute bottom-[18px] sm:bottom-[34px] left-0 right-0 px-4 sm:px-7 lg:px-12"
      >
        <div
          class="inline-block bg-[#fafafa] px-[13px] py-[3px] rounded-[20px] mb-2 shadow-[0_4px_4px_rgba(0,0,0,0.5)]"
        >
          <span
            class="font-display font-bold text-[12px] text-transparent bg-clip-text bg-gradient-to-l from-[#0007d3] to-[#00046d] uppercase"
          >
            {tags[0] || "NEWS"}
          </span>
        </div>
        <h1
          class="font-display font-black text-[19px] sm:text-[26px] lg:text-[34px] text-[#fafafa] leading-[1.2] mb-2.5 max-w-[680px]"
        >
          {title}
        </h1>
        <div class="flex items-center justify-end flex-wrap gap-2">
          <button
            onclick="(() => (history.length === 1) ? window.location = '/' : history.back())()"
            class="jk-btn bg-transparent border border-white rounded-[20px] px-3.5 py-[7px] cursor-pointer font-display font-extrabold text-white text-[12px]"
          >
            ← BACK
          </button>
        </div>
      </div>
    </div>

    {/* ── Content ── */}
    <div
      class="max-w-[1080px] mx-auto px-4 sm:px-7 lg:px-11 pt-[22px] sm:pt-[28px] lg:pt-[36px]"
    >
      <p
        class="font-display font-semibold text-[12px] text-[#1e1e1e]/60 mb-[18px]"
      >
        Published {pubDateStr}
      </p>

      <article
        id="article"
        class="prose max-w-none text-justify mt-8 mb-8 font-display"
      >
        <Content />
      </article>

      <ArticleReactions client:visible />

      {/* ── Related articles ── */}
      <div class="border-t-[2px] border-[#0007d3] pt-[22px] mb-8 lg:mb-12">
        <h2
          class="font-display font-extrabold text-[17px] sm:text-[22px] text-[#000055] mb-[18px]"
        >
          RELATED ARTICLES
        </h2>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-[9px] sm:gap-[18px]">
          {
            recentRelated.map(relatedPost => (
              <SmallCard
                post={relatedPost}
                category={relatedPost.data.tags[0] || "NEWS"}
              />
            ))
          }
        </div>
      </div>
    </div>

    <AppFooter />
  </div>
</Layout>

<style>
  .prose {
    font-size: 14px;
    line-height: 1.85;
  }
  @media (min-width: 640px) {
    .prose {
      font-size: 16px;
    }
  }
  .prose :global(p) {
    @apply mb-[18px];
  }
  .prose :global(p:first-of-type::first-letter) {
    @apply font-bold text-lg;
  }
</style>
