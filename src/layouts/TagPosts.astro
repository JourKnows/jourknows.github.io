---
import { type CollectionEntry } from "astro:content";
import Layout from "@layouts/Layout.astro";
import AppNavbar from "@components/AppNavbar";
import AppFooter from "@components/AppFooter.astro";
import SectionHeader from "@components/SectionHeader.astro";
import HeaderCard from "@components/HeaderCard.astro";
import SmallCard from "@components/SmallCard.astro";
import Pagination from "@components/Pagination.astro";
import { SITE } from "@config";
import { SECTION_COLORS } from "@utils/constants";
import { getCollection } from "astro:content";
import getUniqueTags from "@utils/getUniqueTags";
import getFirstImage from "@utils/getFirstImage";

export interface Props {
  currentPage: number;
  totalPages: number;
  paginatedPosts: CollectionEntry<"blog">[];
  tag: string;
  tagName: string;
}

const { currentPage, totalPages, paginatedPosts, tag, tagName } = Astro.props;

// Find matching section styling
const secColor = SECTION_COLORS[tag] || SECTION_COLORS.default;

const headerPost = paginatedPosts[0];
const smallPosts = paginatedPosts.slice(1);

const heroImage = headerPost ? getFirstImage(headerPost.body) : null;

const allPosts = await getCollection("blog");
const tagsAll = getUniqueTags(allPosts);

const navLinks = [
  { label: "HOME", href: "/" },
  ...tagsAll.map(t => ({
    label: t.tagName.toUpperCase(),
    href: `/tags/${t.tag}`,
  })),
];
---

<Layout title={`Section: ${tagName} | ${SITE.title}`}>
  <AppNavbar client:load activeHref={`/tags/${tag}`} navLinks={navLinks} />

  <div class="jk-page bg-[#f5f6fa] min-h-[100vh]">
    {/* Banner */}
    <div
      class={`relative h-[190px] sm:h-[250px] lg:h-[310px] overflow-hidden ${!heroImage ? secColor : ""}`}
    >
      {
        heroImage && (
          <>
            <img
              src={heroImage}
              alt={tagName}
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-b from-black/20 to-black/75" />
          </>
        )
      }
      <div
        class="absolute bottom-[18px] sm:bottom-[32px] left-0 right-0 px-4 sm:px-7 lg:px-[68px]"
      >
        <h1
          class="font-display font-black text-[26px] sm:text-[34px] lg:text-[44px] text-white mb-1 uppercase drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]"
        >
          {tagName}
        </h1>
        <p
          class="font-display text-[11px] sm:text-[14px] text-white/80 max-w-[520px]"
        >
          Catch up on the latest {tagName.toLowerCase()} updates and insightful articles
          from our contributors.
        </p>
      </div>
    </div>

    <div
      class="max-w-[1280px] mx-auto px-5 sm:px-8 lg:px-[68px] py-[28px] sm:py-[34px] lg:py-[42px] pb-[40px] sm:pb-[48px] lg:pb-[56px] bg-white border border-black/5 sm:rounded-3xl sm:mt-6 lg:mt-8 mb-8 shadow-[0_12px_40px_rgba(0,0,0,0.06)] transition-all duration-500"
    >
      {
        headerPost && (
          <div class="mb-7">
            <SectionHeader label="TOP ARTICLE" color={secColor} />
            <HeaderCard post={headerPost} />
          </div>
        )
      }

      {
        smallPosts.length > 0 && (
          <div>
            <SectionHeader label="LATEST" color={secColor} />
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2.5 sm:gap-[18px] mb-5">
              {smallPosts.map(post => (
                <SmallCard post={post} category={tagName} />
              ))}
            </div>

            <Pagination
              currentPage={currentPage}
              totalPages={totalPages}
              prevUrl={`/tags/${tag}${
                currentPage - 1 !== 1 ? "/" + (currentPage - 1) : ""
              }/`}
              nextUrl={`/tags/${tag}/${currentPage + 1}/`}
            />
          </div>
        )
      }
    </div>

    <AppFooter />
  </div>
</Layout>
