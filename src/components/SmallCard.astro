---
import type { CollectionEntry } from "astro:content";
import getRelativeTime from "@utils/getRelativeTime";
import getFirstImage from "@utils/getFirstImage";

export interface Props {
  post: CollectionEntry<"blog">;
  category?: string;
}

const { post, category } = Astro.props;
const image = getFirstImage(post.body);
---

<a
  href={`/posts/${post.slug}/`}
  class="jk-card bg-transparent overflow-hidden cursor-pointer flex flex-col outline-none group"
>
  {
    image ? (
      <div class="jk-img-container w-full aspect-[8/9] shrink-0">
        <img src={image} alt={post.data.title} />
      </div>
    ) : (
      <div class="jk-img-container w-full aspect-[8/9] shrink-0" />
    )
  }
  <div class="pt-3 pb-2 flex-1 min-w-0 flex flex-col">
    <p
      class="font-display font-bold text-[14px] sm:text-[15px] text-[#151515] mb-[5px] leading-[1.3] line-clamp-3"
    >
      {post.data.title}
    </p>
    <div class="mt-auto">
      <p class="font-sans font-medium text-[11px] italic text-[#555] mb-[1px]">
        by {post.data.author}
      </p>
      <p class="font-sans font-bold text-[11px] italic text-[#333] mb-0">
        {getRelativeTime(post.data.pubDatetime)}
      </p>
    </div>
  </div>
</a>
