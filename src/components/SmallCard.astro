---
import type { CollectionEntry } from "astro:content";
import getRelativeTime from "@utils/getRelativeTime";
import getFirstImage from "@utils/getFirstImage";

export interface Props {
  post: CollectionEntry<"blog">;
  category?: string;
}

const { post, category } = Astro.props;
const image = getFirstImage(post.body);
---

<a
  href={`/posts/${post.slug}/`}
  class="jk-card bg-transparent overflow-hidden cursor-pointer flex flex-col outline-none group"
>
  {
    image ? (
      <div class="w-full aspect-[4/3] bg-gray-200 overflow-hidden shrink-0 rounded">
        <img
          src={image}
          alt={post.data.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        />
      </div>
    ) : (
      <div class="w-full aspect-[4/3] bg-gray-300 shrink-0 rounded" />
    )
  }
  <div class="pt-3 pb-2 flex-1 min-w-0 flex flex-col">
    <span
      class="inline-block bg-[#0007d3] text-white font-display font-bold text-[10px] px-[7px] py-[2px] rounded uppercase mb-2"
    >
      {category}
    </span>
    <p
      class="font-display font-bold text-[14px] sm:text-[15px] text-[#151515] mb-[5px] leading-[1.3] line-clamp-3"
    >
      {post.data.title}
    </p>
    <div class="mt-auto">
      <p class="font-sans font-medium text-[11px] text-[#555] mb-[2px]">
        by {post.data.author}
      </p>
      <p class="font-sans text-[11px] text-[#888] m-0">
        {getRelativeTime(post.data.pubDatetime)}
      </p>
    </div>
  </div>
</a>
