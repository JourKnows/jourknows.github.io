---
import type { CollectionEntry } from "astro:content";
import getRelativeTime from "@utils/getRelativeTime";
import getFirstImage from "@utils/getFirstImage";

export interface Props {
  post: CollectionEntry<"blog">;
  category?: string;
}

const { post } = Astro.props;
const image = getFirstImage(post.body);
---

<a
  href={`/posts/${post.slug}/`}
  class="bg-transparent overflow-hidden cursor-pointer flex flex-col outline-none group p-2 -m-2 rounded-xl transition-all duration-500 hover:bg-white hover:-translate-y-1 hover:shadow-[0_12px_24px_rgba(0,0,0,0.06)]"
>
  {
    image ? (
      <div class="w-full aspect-[8/9] bg-[#d9d9d9] overflow-hidden shrink-0 rounded-[8px]">
        <img
          src={image}
          alt={post.data.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        />
      </div>
    ) : (
      <div class="w-full aspect-[8/9] bg-[#d9d9d9] shrink-0 rounded-[8px]" />
    )
  }
  <div class="pt-3 pb-2 flex-1 min-w-0 flex flex-col">
    <p
      class="font-display font-bold text-[14px] sm:text-[15px] text-[#151515] group-hover:text-[#00046d] transition-colors duration-300 mb-[5px] leading-[1.3] line-clamp-3"
    >
      {post.data.title}
    </p>
    <div class="mt-auto">
      <p class="font-sans font-medium text-[11px] italic text-[#555] mb-[1px]">
        by {post.data.author}
      </p>
      <p class="font-sans font-bold text-[11px] italic text-[#333] mb-0">
        {getRelativeTime(post.data.pubDatetime)}
      </p>
    </div>
  </div>
</a>
