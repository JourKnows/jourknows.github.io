---
import { SOCIALS } from "../config";
import socialIcons from "../assets/socialIcons";

const LOGO =
  "https://i0.wp.com/jourknowsph.com/wp-content/uploads/2026/02/untitled-1920-x-900-px-1920-x-750-px.png?fit=1920%2C750&ssl=1";
const LETTER_ICON = "/assets/letter-icon.svg";
const JOURKNOWS_DESC =
  "JourKnows PH is a student journalism publication committed to amplifying youth voices and delivering stories that matter — Journalism for All.";
---

<footer
  class="jk-footer bg-[#05051a]/85 backdrop-blur-[64px] saturate-150 text-white/85 pt-12 sm:pt-16 pb-8 w-[92%] max-w-[1100px] mx-auto sm:mb-10 mt-12 rounded-[32px] sm:rounded-[40px] border border-white/10 shadow-[0_40px_80px_rgba(0,0,40,0.15)] animate-glassFadeUp"
  style="animation-delay: 500ms;"
>
  <div
    class="w-full px-6 sm:px-12 lg:px-16 grid grid-cols-1 sm:grid-cols-[1fr_2fr_1fr] gap-6 sm:gap-10"
  >
    <!-- Logo & Description -->
    <div>
      <img
        src={LOGO}
        alt="JourKnows"
        class="h-[44px] w-auto mb-2.5 object-contain"
      />
      <p
        class="text-[11px] opacity-80 leading-[1.75] max-w-[220px] font-display"
      >
        {JOURKNOWS_DESC}
      </p>
    </div>

    <!-- Newsletter & Socials -->
    <div>
      <p class="font-display font-extrabold text-[13px] mb-2.5">
        Subscribe to our newsletter
      </p>
      <form class="flex mb-3 max-w-sm">
        <div
          class="flex items-center bg-white/5 border border-white/10 flex-1 rounded-[24px] overflow-hidden p-1 shadow-inner focus-within:bg-white/10 focus-within:border-white/20 transition-all duration-300"
        >
          <img
            src={LETTER_ICON}
            alt=""
            class="w-[14px] h-[14px] mx-3 opacity-60 object-contain shrink-0"
          />
          <input
            type="email"
            placeholder="your@email.com"
            class="flex-1 bg-transparent border-none outline-none text-white/90 text-[13px] font-display py-2 px-1 min-w-0 placeholder:text-white/40"
            required
          />
          <button
            type="submit"
            class="jk-btn bg-white border-none cursor-pointer font-display font-bold text-[#000010] text-[11px] px-4 py-2 rounded-[20px] whitespace-nowrap hover:bg-[#e0e0e0] transition-colors"
          >
            SUBSCRIBE
          </button>
        </div>
      </form>
      <div class="flex gap-4">
        {
          SOCIALS.filter(social => social.active).map(social => (
            <a
              href={social.href}
              class="hover:opacity-100 opacity-90 transition-opacity"
              title={social.linkTitle}
            >
              <Fragment set:html={socialIcons[social.name]} />
            </a>
          ))
        }
      </div>
    </div>

    <!-- Links -->
    <div class="flex gap-6">
      <div>
        <p class="font-display font-extrabold text-[12px] mb-2">JourKnows PH</p>
        {
          ["About Us", "Contact Us", "Privacy Policy"].map(link => (
            <a
              href="#"
              class="block font-display text-[12px] mb-1.5 cursor-pointer opacity-85 hover:opacity-100 hover:text-white transition-opacity"
            >
              {link}
            </a>
          ))
        }
      </div>
      <div>
        <p class="font-display font-extrabold text-[12px] mb-2">Quick Links</p>
        {
          ["Volunteer", "Subscribe"].map(link => (
            <a
              href="#"
              class="block font-display text-[12px] mb-1.5 cursor-pointer opacity-85 hover:opacity-100 hover:text-white transition-opacity"
            >
              {link}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div
    class="mt-12 text-center font-display text-[12px] text-white/40 pt-6 border-t border-white/10"
  >
    © JourKnows 2025. All rights reserved.
  </div>
</footer>
