---
import type { CollectionEntry } from "astro:content";
import getRelativeTime from "@utils/getRelativeTime";
import getFirstImage from "@utils/getFirstImage";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const tag = post.data.tags?.[0] || "NEWS";
const image = getFirstImage(post.body);
---

<a
  href={`/posts/${post.slug}/`}
  class="jk-card bg-transparent overflow-hidden cursor-pointer flex flex-row items-stretch outline-none group border-b border-gray-200 pb-4 mb-4"
>
  {
    image ? (
      <div class="w-[120px] sm:w-[160px] aspect-[4/3] bg-gray-200 overflow-hidden shrink-0 rounded">
        <img
          src={image}
          alt={post.data.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        />
      </div>
    ) : (
      <div class="w-[120px] sm:w-[160px] aspect-[4/3] bg-gray-300 shrink-0 rounded" />
    )
  }
  <div class="pl-4 flex-1 min-w-0 flex flex-col justify-center">
    <span
      class="inline-block bg-[#0007d3] text-white font-display font-bold text-[10px] px-[7px] py-[2px] rounded uppercase mb-1.5"
    >
      {tag}
    </span>
    <p
      class="font-display font-bold text-[14px] sm:text-[16px] text-[#151515] mb-2 leading-[1.3] line-clamp-2"
    >
      {post.data.title}
    </p>
    <p class="font-sans font-medium text-[11px] text-[#555] mb-[3px]">
      by {post.data.author}
    </p>
    <p class="font-sans text-[11px] text-[#888] m-0">
      {getRelativeTime(post.data.pubDatetime)}
    </p>
  </div>
</a>
