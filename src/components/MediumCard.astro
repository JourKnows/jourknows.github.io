---
import type { CollectionEntry } from "astro:content";
import getRelativeTime from "@utils/getRelativeTime";
import getFirstImage from "@utils/getFirstImage";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const tag = post.data.tags?.[0] || "NEWS";
const image = getFirstImage(post.body);
---

<a
  href={`/posts/${post.slug}/`}
  class="jk-card bg-transparent overflow-hidden cursor-pointer flex flex-col sm:flex-row outline-none group pb-4 mb-4 sm:border-b sm:border-gray-200"
>
  {
    image ? (
      <div class="w-full sm:w-[160px] aspect-[4/3] bg-[#d9d9d9] overflow-hidden shrink-0 rounded-[8px]">
        <img
          src={image}
          alt={post.data.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        />
      </div>
    ) : (
      <div class="w-full sm:w-[160px] aspect-[4/3] bg-[#d9d9d9] shrink-0 rounded-[8px]" />
    )
  }
  <div
    class="pt-3 sm:pt-0 sm:pl-4 flex-1 min-w-0 flex flex-col sm:justify-center"
  >
    <span
      class="font-display font-extrabold text-[11px] text-[#111] uppercase tracking-[0.5px] mb-1.5"
    >
      {tag}
    </span>
    <p
      class="font-display font-bold text-[14px] sm:text-[16px] text-[#151515] mb-2 leading-[1.3] line-clamp-2"
    >
      {post.data.title}
    </p>
    <p class="font-sans font-medium text-[11px] italic text-[#555] mb-[1px]">
      by {post.data.author}
    </p>
    <p class="font-sans font-bold text-[11px] italic text-[#333] m-0">
      {getRelativeTime(post.data.pubDatetime)}
    </p>
  </div>
</a>
