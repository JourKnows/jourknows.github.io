---
import type { CollectionEntry } from "astro:content";
import getRelativeTime from "@utils/getRelativeTime";
import getFirstImage from "@utils/getFirstImage";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const tag = post.data.tags?.[0] || "NEWS";
const image = getFirstImage(post.body);
---

<a
  href={`/posts/${post.slug}/`}
  class="jk-card bg-transparent overflow-hidden cursor-pointer flex flex-col sm:flex-row outline-none group mb-2"
>
  {
    image ? (
      <div class="w-full sm:w-[45%] aspect-[3/2] bg-gray-200 overflow-hidden shrink-0 rounded">
        <img
          src={image}
          alt={post.data.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        />
      </div>
    ) : (
      <div class="w-full sm:w-[45%] aspect-[3/2] bg-gray-300 shrink-0 rounded" />
    )
  }
  <div class="pt-3 sm:pt-0 sm:pl-5 flex-1 min-w-0 flex flex-col justify-center">
    <span
      class="inline-block bg-[#0007d3] text-white font-display font-bold text-[10px] px-[7px] py-[2px] rounded uppercase mb-2"
    >
      {tag}
    </span>
    <p
      class="font-display font-bold text-[18px] sm:text-[22px] text-[#151515] mb-[7px] leading-[1.3] line-clamp-2 sm:line-clamp-3"
    >
      {post.data.title}
    </p>
    <p class="font-sans font-medium text-[12px] text-[#555] mb-1">
      by {post.data.author}
    </p>
    <p class="font-sans text-[12px] text-[#888] mb-0 sm:mb-2.5">
      {getRelativeTime(post.data.pubDatetime)}
    </p>
    <p
      class="hidden sm:block font-display text-[14px] text-[#444] leading-[1.6] line-clamp-3 mt-2"
    >
      {post.data.description}
    </p>
  </div>
</a>
