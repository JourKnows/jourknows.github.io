---
import type { CollectionEntry } from "astro:content";
import getRelativeTime from "@utils/getRelativeTime";
import getFirstImage from "@utils/getFirstImage";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const tag = post.data.tags?.[0] || "NEWS";
const image = getFirstImage(post.body);
---

<a
  href={`/posts/${post.slug}/`}
  class="jk-card bg-[#f4f4f4] rounded-[10px] overflow-hidden cursor-pointer flex flex-col sm:flex-row shadow-[0_1px_4px_rgba(0,0,0,0.08)] outline-none group"
>
  {
    image && (
      <div class="w-full sm:w-2/5 aspect-square overflow-hidden shrink-0">
        <img
          src={image}
          alt={post.data.title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        />
      </div>
    )
  }
  <div class="px-3 py-3 sm:px-5 sm:py-[18px] flex-1 min-w-0">
    <span
      class="inline-block bg-[#0007d3] text-white font-display font-bold text-[10px] px-[7px] py-[2px] rounded uppercase mb-2"
    >
      {tag}
    </span>
    <p
      class="font-display font-bold text-[15px] sm:text-[19px] text-[#151515] mb-[7px] leading-[1.4] line-clamp-2 sm:line-clamp-3"
    >
      {post.data.title}
    </p>
    <p class="font-sans italic text-[12px] text-[#555] mb-1.5">
      by {post.data.author}
    </p>
    <p class="font-sans text-[11px] text-[#888] mb-0 sm:mb-2.5">
      {getRelativeTime(post.data.pubDatetime)}
    </p>
    <p
      class="hidden sm:block font-display text-[13px] text-[#333] leading-[1.6]"
    >
      {post.data.description}
    </p>
  </div>
</a>
