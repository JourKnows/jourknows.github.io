---
import type { CollectionEntry } from "astro:content";
import getRelativeTime from "@utils/getRelativeTime";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

<a
  href={`/posts/${post.slug}/`}
  class="jk-card bg-[#f4f4f4] rounded-[10px] overflow-hidden cursor-pointer flex flex-col sm:flex-row shadow-[0_1px_4px_rgba(0,0,0,0.08)] outline-none"
>
  <div
    class="bg-[#d9d9d9] w-full sm:w-[340px] sm:min-w-[340px] h-[170px] sm:h-[210px] shrink-0"
  >
  </div>
  <div class="px-3 py-3 sm:px-5 sm:py-[18px]">
    <p
      class="font-display font-bold text-[15px] sm:text-[19px] text-[#151515] mb-[7px] leading-[1.4] line-clamp-2 sm:line-clamp-3"
    >
      {post.data.title}
    </p>
    <p class="font-sans italic text-[12px] text-[#555] mb-1.5">
      by {post.data.author}
    </p>
    <p class="font-sans text-[11px] text-[#888] mb-0 sm:mb-2.5">
      {getRelativeTime(post.data.pubDatetime)}
    </p>
    <p
      class="hidden sm:block font-display text-[13px] text-[#333] leading-[1.6]"
    >
      {post.data.description}
    </p>
  </div>
</a>
