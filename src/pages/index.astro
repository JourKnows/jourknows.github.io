---
import { getCollection } from "astro:content";
import getSortedPosts from "@utils/getSortedPosts";
import getUniqueTags from "@utils/getUniqueTags";
import getAllImages from "@utils/getAllImages";
import "@styles/base.css";
import AppNavbar from "@components/AppNavbar";
import CartoonComicViewer from "@components/CartoonComicViewer";
import LatestDeckViewer from "@components/LatestDeckViewer";
import ExplainerGallery from "@components/ExplainerGallery";
import AppFooter from "@components/AppFooter.astro";
import SectionHeader from "@components/SectionHeader.astro";
import HeaderCard from "@components/HeaderCard.astro";

import SmallCard from "@components/SmallCard.astro";
import { SECTION_COLORS } from "@utils/constants";
import getFirstImage from "@utils/getFirstImage";
import { slugifyAll } from "@utils/slugify";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const allTags = getUniqueTags(posts);

const SECTION_ORDER = [
  "news",
  "sports",
  "opinion",
  "feature",
  "sci-tech",
  "explainer",
  "literary",
  "cartoon",
];

const categoryTags = [...allTags].sort((a, b) => {
  const aIdx = SECTION_ORDER.indexOf(a.tag);
  const bIdx = SECTION_ORDER.indexOf(b.tag);
  if (aIdx !== -1 && bIdx !== -1) return aIdx - bIdx;
  if (aIdx !== -1) return -1;
  if (bIdx !== -1) return 1;
  return a.tagName.localeCompare(b.tagName);
});
const navLinks = [
  { label: "HOME", href: "/" },
  ...allTags.map(t => ({
    label: t.tagName.toUpperCase(),
    href: `/tags/${t.tag}`,
  })),
];

const latestPosts = sortedPosts;

// Get categorised posts simply
const getPostsByCategory = (cat: string) => {
  return sortedPosts
    .filter(p => slugifyAll(p.data.tags || []).includes(cat))
    .slice(0, 4);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <title>JourKnows | Home</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,400&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-display min-h-[100vh] bg-[#f5f6fa] m-0 p-0 text-[#1e1e1e]">
    <AppNavbar client:load activeHref="/" navLinks={navLinks} />

    <div>
      {/* ── Latest ── */}
      {
        latestPosts.length > 0 && (
          <div class="w-full relative bg-white overflow-hidden shadow-[0_12px_40px_rgba(0,0,0,0.06)] mb-3 sm:mb-5">
            <LatestDeckViewer
              client:visible
              posts={latestPosts.map(p => ({
                title: p.data.title || "Untitled",
                slug: p.slug || "",
                author: p.data.author || "JourKnows",
                image: getFirstImage(p.body) || null,
                date: p.data.pubDatetime
                  ? new Date(p.data.pubDatetime).toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })
                  : "Unknown Date",
                tag: p.data.tags?.[0] || "NEWS",
                description: p.data.description || "",
              }))}
            />
          </div>
        )
      }

      {/* ── Category sections ── */}
      <div class="animate-glassFadeUp" style="animation-delay: 300ms;">
        {
          categoryTags.map(tagObj => {
            const catTag = tagObj.tag;
            const label = tagObj.tagName.toUpperCase();
            const color = SECTION_COLORS[catTag] || SECTION_COLORS.default;

            // grab posts for this category tag
            const catPosts = getPostsByCategory(catTag);
            if (catPosts.length === 0) return null; // hide section if no posts

            if (catTag === "cartoon") {
              const mappedPosts = catPosts.map(p => ({
                title: p.data.title || "Untitled",
                slug: p.slug || "",
                author: p.data.author || "JourKnows",
                image:
                  getFirstImage(p.body) ||
                  "https://placehold.co/800x800/f4f1e1/1a1a1a?text=Artwork+Unavailable",
                date: p.data.pubDatetime
                  ? new Date(p.data.pubDatetime).toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "short",
                      day: "numeric",
                    })
                  : "Unknown Date",
              }));

              return (
                <div class="mb-3 sm:mb-5 sm:mx-5 lg:mx-10 sm:rounded-2xl bg-white overflow-hidden shadow-[0_12px_40px_rgba(0,0,0,0.06)]">
                  <CartoonComicViewer client:visible posts={mappedPosts} />
                </div>
              );
            }

            if (catTag === "explainer") {
              const explainerPost = catPosts[0];
              if (!explainerPost) return null;

              const images = getAllImages(explainerPost.body);

              return (
                <div class="bg-white px-[16px] sm:px-[28px] lg:px-[68px] py-[28px] sm:py-[34px] lg:py-[40px] pb-[36px] sm:pb-[42px] lg:pb-[48px] sm:mx-5 lg:mx-10 sm:rounded-2xl mb-3 sm:mb-5">
                  <SectionHeader label={label} color={color} />

                  <div class="mt-5 mb-8">
                    <ExplainerGallery
                      client:visible
                      title={explainerPost.data.title || "Untitled"}
                      slug={explainerPost.slug || ""}
                      author={explainerPost.data.author || "JourKnows"}
                      date={
                        explainerPost.data.pubDatetime
                          ? new Date(
                              explainerPost.data.pubDatetime
                            ).toLocaleDateString("en-US", {
                              year: "numeric",
                              month: "long",
                              day: "numeric",
                            })
                          : "Unknown Date"
                      }
                      description={explainerPost.data.description || ""}
                      images={images}
                    />
                  </div>

                  <div class="mt-8 text-center">
                    <a
                      href={`/tags/${catTag}`}
                      class="bg-[#00046d] border-none rounded-[20px] px-8 py-2.5 cursor-pointer font-display font-medium text-white text-[12px] uppercase tracking-wide inline-block no-underline shadow-md"
                    >
                      READ MORE
                    </a>
                  </div>
                </div>
              );
            }

            const headerPost = catPosts[0];
            const smallPosts = catPosts.slice(1, 4);

            return (
              <div class="bg-white px-[16px] sm:px-[28px] lg:px-[68px] py-[28px] sm:py-[34px] lg:py-[40px] pb-[36px] sm:pb-[42px] lg:pb-[48px] sm:mx-5 lg:mx-10 sm:rounded-2xl mb-3 sm:mb-5">
                <SectionHeader label={label} color={color} />
                <div class="mb-5">
                  <HeaderCard post={headerPost} />
                </div>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-2.5 sm:gap-4 lg:gap-[18px]">
                  {smallPosts.map((post, i) => (
                    <div class={i === 2 ? "hidden sm:block" : ""}>
                      <SmallCard post={post} category={label} />
                    </div>
                  ))}
                </div>
                <div class="mt-8 text-center">
                  <a
                    href={`/tags/${catTag}`}
                    class="bg-[#00046d] border-none rounded-[20px] px-8 py-2.5 cursor-pointer font-display font-medium text-white text-[12px] uppercase tracking-wide inline-block no-underline shadow-md"
                  >
                    READ MORE
                  </a>
                </div>
              </div>
            );
          })
        }
      </div>

      <AppFooter />
    </div>
  </body>
</html>
