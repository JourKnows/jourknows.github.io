---
import { getCollection } from "astro:content";
import getSortedPosts from "@utils/getSortedPosts";
import getUniqueTags from "@utils/getUniqueTags";
import "@styles/base.css";
import AppNavbar from "@components/AppNavbar";
import AppFooter from "@components/AppFooter.astro";
import SectionHeader from "@components/SectionHeader.astro";
import HeaderCard from "@components/HeaderCard.astro";
import MediumCard from "@components/MediumCard.astro";
import SmallCard from "@components/SmallCard.astro";
import { HERO_IMG, SECTION_COLORS } from "@utils/constants";
import getFirstImage from "@utils/getFirstImage";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const allTags = getUniqueTags(posts);
const categoryTags = allTags;

const navLinks = [
  { label: "HOME", href: "/" },
  ...allTags.map(t => ({
    label: t.tagName.toUpperCase(),
    href: `/tags/${t.tag}`,
  })),
];

// Fallback logic for demo
const heroPost = sortedPosts[0];
const heroImage = heroPost ? getFirstImage(heroPost.body) : null;

const latestPosts = sortedPosts.slice(1, 5);

// Get categorised posts simply
const getPostsByCategory = (cat: string) => {
  return sortedPosts
    .filter(p => p.data.tags?.includes(cat.toLowerCase()))
    .slice(0, 4);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>JourKnows | Home</title>
  </head>
  <body
    class="font-display min-h-[100vh] bg-white overflow-x-hidden max-w-[100vw] m-0 p-0 text-[#1e1e1e]"
  >
    <AppNavbar client:load activeHref="/" navLinks={navLinks} />

    <div class="jk-page">
      {/* ── Hero ── */}
      {
        heroPost && (
          <div
            class={`relative h-[310px] sm:h-[400px] lg:h-[510px] overflow-hidden ${!heroImage ? "bg-white" : ""}`}
          >
            {heroImage && (
              <>
                <img
                  src={heroImage}
                  alt={heroPost.data.title}
                  class="w-full h-full object-cover"
                />
                <div class="absolute inset-0 bg-gradient-to-b from-black/10 to-black/75" />
              </>
            )}
            <div class="absolute bottom-[22px] sm:bottom-[38px] left-0 right-0 px-[16px] sm:px-[28px] lg:px-[68px]">
              <div class="inline-block bg-white px-[12px] py-[3px] rounded-[20px] mb-2.5 shadow-[0_2px_4px_rgba(0,0,0,0.3)]">
                <span class="font-display font-bold text-[11px] text-[#00046d] uppercase tracking-wide">
                  {heroPost.data.tags?.[0] || "NEWS"}
                </span>
              </div>
              <h1
                class={`font-display font-black text-[22px] sm:text-[32px] lg:text-[42px] ${heroImage ? "text-[#fafafa] drop-shadow-[0_2px_6px_rgba(0,0,0,0.6)]" : "text-[#00046d]"} leading-[1.2] mb-3 max-w-[800px]`}
              >
                {heroPost.data.title}
              </h1>
              <div class="flex items-center justify-between gap-5 mt-3">
                <div class="flex items-center gap-2.5">
                  <div class="w-8 h-8 rounded-full bg-[#00046d] flex items-center justify-center overflow-hidden shrink-0 border border-white/50 shadow-sm">
                    <span class="text-white text-[12px] font-bold">
                      {heroPost.data.author.charAt(0).toUpperCase()}
                    </span>
                  </div>
                  <div class="flex flex-col">
                    <span
                      class={`font-display font-bold text-[12px] ${heroImage ? "text-white" : "text-[#333]"}`}
                    >
                      by {heroPost.data.author}
                    </span>
                    <span
                      class={`font-sans text-[10px] ${heroImage ? "text-white/80" : "text-[#666]"}`}
                    >
                      {new Date(heroPost.data.pubDatetime).toLocaleDateString(
                        "en-US",
                        { year: "numeric", month: "long", day: "numeric" }
                      )}
                    </span>
                  </div>
                </div>
                <a
                  href={`/posts/${heroPost.slug}/`}
                  class={`shrink-0 border ${heroImage ? "border-white text-white" : "border-[#00046d] text-[#00046d]"} uppercase rounded-[20px] px-4 py-1.5 cursor-pointer font-display font-bold text-[10px] tracking-wide no-underline`}
                >
                  READ MORE
                </a>
              </div>
            </div>
          </div>
        )
      }

      {/* ── Latest ── */}
      {
        latestPosts.length > 0 && (
          <div class="bg-white px-[16px] sm:px-[28px] lg:px-[68px] py-[22px] sm:py-[26px] lg:py-[30px] pb-[30px] sm:pb-[34px] lg:pb-[38px]">
            <div class="flex items-center mb-3.5">
              <h2 class="font-display font-extrabold text-[17px] sm:text-[21px] text-[#1a1a1a] shrink-0 mr-3">
                LATEST
              </h2>
              <div class="flex-1 h-[3px] bg-gradient-to-r from-[#041eb0] to-[#fffbfb] rounded" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5 sm:gap-3.5">
              {latestPosts.map(post => (
                <MediumCard post={post} />
              ))}
            </div>
          </div>
        )
      }

      {/* ── Category sections ── */}
      <div class="bg-white">
        {
          categoryTags.map(tagObj => {
            const catTag = tagObj.tag;
            const label = tagObj.tagName.toUpperCase();
            const color = SECTION_COLORS[catTag] || SECTION_COLORS.default;

            // grab posts for this category tag
            const catPosts = getPostsByCategory(catTag);
            if (catPosts.length === 0) return null; // hide section if no posts

            const headerPost = catPosts[0];
            const smallPosts = catPosts.slice(1, 4);

            return (
              <div class="px-[16px] sm:px-[28px] lg:px-[68px] py-[22px] sm:py-[26px] lg:py-[30px] pb-[32px] sm:pb-[38px] lg:pb-[44px]">
                <SectionHeader label={label} color={color} />
                <div class="mb-5">
                  <HeaderCard post={headerPost} />
                </div>
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-2.5 sm:gap-4 lg:gap-[18px]">
                  {smallPosts.map((post, i) => (
                    <div class={i === 2 ? "hidden sm:block" : ""}>
                      <SmallCard post={post} category={label} />
                    </div>
                  ))}
                </div>
                <div class="mt-8 text-center">
                  <a
                    href={`/tags/${catTag}`}
                    class="bg-[#00046d] border-none rounded-[20px] px-8 py-2.5 cursor-pointer font-display font-medium text-white text-[12px] uppercase tracking-wide inline-block no-underline shadow-md"
                  >
                    READ MORE
                  </a>
                </div>
              </div>
            );
          })
        }
      </div>

      <AppFooter />
    </div>
  </body>
</html>
